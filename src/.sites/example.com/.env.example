# Site-Specific Environment Configuration
# This file is loaded AFTER the root .env file

# Site URL with protocol
VITE_SITE_NAME=https://example.com

# Default author for blog posts
DEFAULT_AUTHOR=A.N.Other

#github
PUBLIC_GITHUB_REPO_OWNER=hiive
PUBLIC_GITHUB_REPO=example.com

#git/github
GITHUB_TOKEN=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=

#docker
DOCKER_BLOG_PORT=8464
DOCKER_BLOG_CODE=example

LLM_PROVIDER=openai

LLM_OPENAI_API_KEY=


# Deployment Configuration
DEPLOY_TARGET=wisp
WISP_HANDLE=
# Bluesky App Password (required for wisp deployment)
WISP_APP_PASSWORD=
# Must match the subdomain you set up on wisp.place
# Example: If set to "hiivelabs", your site will be at hiivelabs.wisp.place
WISP_SITE_NAME=example
