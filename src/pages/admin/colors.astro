---
// the following line will be automatically commented out
// by the build process for production builds.
export const prerender = false; // ![DEV-ONLY]

import BaseHead from '../../components/BaseHead.astro';
import '../../styles/admin.css';
import { ThemeEditor, LocalThemeToggle } from '../../components/admin/ThemeEditor';

const title = 'Theme Editor';
const description = 'Edit the color scheme and background images for light and dark modes';
const permalink = Astro.url.pathname;
---

<html lang="en">
<head>
    <BaseHead title={title} description={description} permalink={permalink} />
    <style is:global>
        /* Override container width for color editor */
        .container {
            max-width: 1200px;
        }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
            border-bottom: 2px solid rgb(var(--primary-color));
            padding-bottom: 0.5rem;
        }

        h1 {
            color: rgb(var(--heading-color));
            margin: 0;
            border: none;
            padding: 0;
        }

        .theme-toggle-container {
            display: flex;
            align-items: center;
            width: 5rem;
        }

        .theme-toggle-container .theme-toggle {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.5rem;
            margin-left: 0.5rem;
            gap: 0.5rem;
            border-radius: 9999px;
        }

        .theme-toggle-container .theme-toggle .checked {
            opacity: 1;
        }

        .theme-toggle-container .theme-toggle label {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0.5;
            color: rgb(var(--text-main));
        }

        .theme-toggle-container .theme-toggle label.checked {
            opacity: 1;
        }

        .theme-toggle-container .theme-toggle input[type='radio'] {
            position: absolute;
            opacity: 0;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            z-index: -1;
        }

        .theme-toggle-container .theme-toggle label:focus-within {
            outline: 2px solid transparent;
        }

        .subtitle {
            color: rgb(var(--text-secondary));
            margin-bottom: 2rem;
        }

        /* Color Editor Styles */
        .color-editor {
            width: 100%;
        }

        .loading {
            text-align: center;
            padding: 2rem;
            color: rgb(var(--text-secondary));
        }

        .error-message {
            background: rgba(var(--secondary-color), 0.15);
            border: 1px solid rgba(var(--secondary-color), 0.3);
            color: rgb(var(--secondary-color));
            padding: 1rem;
            border-radius: 4px;
            margin-bottom: 1rem;
        }

        .success-message {
            background: rgba(var(--hiive-crt), 0.15);
            border: 1px solid rgba(var(--hiive-crt), 0.3);
            color: rgb(var(--hiive-crt));
            padding: 1rem;
            border-radius: 4px;
            margin-bottom: 1rem;
        }

        .toolbar {
            display: flex;
            gap: 1rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: 1rem;
            background: rgb(var(--background-body));
            border-radius: 4px;
        }

        .toolbar.bottom {
            margin-top: 1rem;
            margin-bottom: 0;
        }

        .save-btn {
            background: rgb(var(--hiive-crt));
            color: rgb(var(--primary-color-contrast));
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            font-weight: 600;
        }

        .save-btn:hover:not(:disabled) {
            filter: brightness(1.1);
        }

        .save-btn:disabled {
            background: rgb(var(--background-mid));
            color: rgb(var(--text-secondary));
            cursor: not-allowed;
        }

        .reset-btn {
            background: rgb(var(--background-mid));
            color: rgb(var(--text-main));
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
        }

        .reset-btn:hover:not(:disabled) {
            background: rgb(var(--primary-color-alt));
        }

        .reset-btn:disabled {
            background: rgb(var(--background-mid));
            color: rgb(var(--text-secondary));
            cursor: not-allowed;
            opacity: 0.6;
        }

        .unsaved-indicator {
            color: rgb(var(--secondary-color));
            font-weight: 600;
            margin-left: auto;
        }

        .color-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .color-table th,
        .color-table td {
            padding: 0.75rem;
            text-align: left;
            border: 1px solid rgb(var(--background-mid));
            vertical-align: top;
        }

        .color-table th {
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .name-header {
            width: 30%;
            background: rgb(var(--background-body));
            color: rgb(var(--text-main));
        }

        /* Dark header stays fixed black */
        .dark-header {
            width: 32%;
            background: #1a1a1a;
            color: white;
        }

        /* Sync header column */
        .sync-header {
            width: 6%;
            background: linear-gradient(to right, #1a1a1a 50%, #f8f9fa 50%);
            text-align: center;
            vertical-align: middle;
            padding: 0.5rem;
        }

        .sync-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            margin: 0 auto;
            border: 2px solid #666;
            border-radius: 50%;
            background: rgb(var(--background-feature));
            color: rgb(var(--text-secondary));
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .sync-toggle:hover {
            border-color: rgb(var(--primary-color));
            color: rgb(var(--text-main));
        }

        .sync-toggle.active {
            background: rgb(var(--primary-color));
            border-color: rgb(var(--primary-color));
            color: rgb(var(--primary-color-contrast));
        }

        .sync-toggle.partial {
            border-color: rgb(var(--primary-color));
            background: rgba(var(--primary-color), 0.3);
        }

        .sync-toggle svg {
            width: 16px;
            height: 16px;
        }

        /* Row-level sync toggle button */
        .sync-toggle-row {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            margin: 0 auto;
            border: 1px solid #888;
            border-radius: 4px;
            background: transparent;
            color: #888;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .sync-toggle-row:hover {
            border-color: rgb(var(--primary-color));
            color: rgb(var(--primary-color));
        }

        .sync-toggle-row.active {
            background: rgb(var(--primary-color));
            border-color: rgb(var(--primary-color));
            color: rgb(var(--primary-color-contrast));
        }

        .sync-toggle-row svg {
            width: 14px;
            height: 14px;
        }

        /* Light header stays fixed white */
        .light-header {
            width: 32%;
            background: #f8f9fa;
            color: #333;
        }

        .name-cell {
            background: rgb(var(--background-body));
        }

        .color-name {
            display: block;
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: rgb(var(--text-highlight-color));
        }

        .color-var {
            display: block;
            font-size: 0.8rem;
            color: rgb(var(--text-secondary));
            background: rgb(var(--background-mid) / 0.3);
            padding: 2px 6px;
            border-radius: 3px;
        }

        /* Dark column stays fixed black */
        .dark-bg {
            background: #1a1a1a;
        }

        /* Sync column in body rows */
        .sync-cell {
            background: linear-gradient(to right, #1a1a1a 50%, #ffffff 50%);
            width: 6%;
        }

        /* Light column stays fixed white */
        .light-bg {
            background: #ffffff;
        }

        /* Merged cell for theme-independent colors */
        .merged-bg {
            background: linear-gradient(to right, #1a1a1a 0%, #1a1a1a 45%, #888 50%, #ffffff 55%, #ffffff 100%);
        }

        .color-input-wrapper {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        /* Table row separation */
        .color-table tbody tr {
            border-bottom: 8px solid rgb(var(--background-body));
        }

        /* Color swatch styles */
        .color-swatch-wrapper {
            position: relative;
            display: block;
            width: 100%;
        }

        .color-swatch {
            width: 100%;
            height: 50px;
            border-radius: 6px;
            cursor: pointer;
            border: 2px solid rgba(128, 128, 128, 0.3);
            transition: box-shadow 0.15s ease, border-color 0.15s ease;
        }

        .color-swatch:hover {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            border-color: rgba(128, 128, 128, 0.6);
        }

        /* Color picker popup */
        .color-picker-popup {
            position: absolute;
            top: 100%;
            left: 0;
            z-index: 1000;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
            padding: 16px;
            margin-top: 8px;
        }

        .dark-bg .color-picker-popup {
            background: #2a2a2a;
        }

        .iro-picker-container {
            margin-bottom: 12px;
        }

        .picker-buttons {
            display: flex;
            gap: 6px;
        }

        .cancel-picker-btn {
            flex: 1;
            padding: 5px 12px;
            background: rgb(var(--background-mid));
            color: rgb(var(--text-main));
            border: none;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
        }

        .cancel-picker-btn:hover {
            filter: brightness(1.1);
        }

        .close-picker-btn {
            flex: 1;
            padding: 5px 12px;
            background: rgb(var(--primary-color));
            color: rgb(var(--primary-color-contrast));
            border: none;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
        }

        .close-picker-btn:hover {
            filter: brightness(1.1);
        }

        /* Color input section with format switcher */
        .color-input-section {
            margin-bottom: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .format-switcher {
            display: flex;
            gap: 4px;
            background: rgba(128, 128, 128, 0.2);
            border-radius: 4px;
            padding: 2px;
        }

        .format-btn {
            flex: 1;
            padding: 4px 8px;
            border: none;
            background: transparent;
            color: #666;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 3px;
            transition: all 0.15s ease;
        }

        .format-btn:hover {
            background: rgba(128, 128, 128, 0.2);
            color: #333;
        }

        .format-btn.active {
            background: rgb(var(--primary-color));
            color: rgb(var(--primary-color-contrast));
        }

        .dark-bg .format-btn {
            color: #999;
        }

        .dark-bg .format-btn:hover {
            color: #fff;
        }

        .dark-bg .format-btn.active {
            background: rgb(var(--primary-color));
            color: rgb(var(--primary-color-contrast));
        }

        /* Four component inputs layout (RGB/HSL) */
        .component-inputs {
            display: flex;
            gap: 6px;
        }

        .component-input {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
        }

        .component-input label {
            font-size: 9px;
            font-weight: 600;
            color: #666;
            margin-bottom: 1px;
            text-transform: uppercase;
            line-height: 1;
        }

        .component-input input {
            width: 100%;
            padding: 4px 2px;
            border: 1px solid rgba(128, 128, 128, 0.3);
            border-radius: 3px;
            font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
            font-size: 11px;
            text-align: center;
            background: #fff;
            color: #333;
            -moz-appearance: textfield;
        }

        .component-input input::-webkit-outer-spin-button,
        .component-input input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .component-input input:focus {
            outline: none;
            border-color: rgb(var(--primary-color));
            box-shadow: 0 0 0 2px rgba(var(--primary-color), 0.2);
        }

        /* HEX input wrapper with label */
        .hex-input-wrapper {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .hex-label {
            font-size: 9px;
            font-weight: 600;
            color: #666;
            margin-bottom: 1px;
            text-transform: uppercase;
            line-height: 1;
        }

        .color-picker-popup .hex-label {
            color: #999;
        }

        /* HEX input group with # prefix */
        .hex-input-group {
            display: flex;
            align-items: stretch;
            width: 200px; /* Match iro picker width */
        }

        .hex-prefix {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
            background: #1a1a1a;
            border: 1px solid rgba(128, 128, 128, 0.3);
            border-right: none;
            border-radius: 3px 0 0 3px;
            font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
            font-size: 11px;
            font-weight: 600;
            color: #999;
            user-select: none;
        }

        .hex-input {
            flex: 1;
            padding: 4px 6px;
            border: 1px solid rgba(128, 128, 128, 0.3);
            border-radius: 0 3px 3px 0;
            font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
            font-size: 11px;
            background: #fff;
            color: #333;
            text-transform: lowercase;
        }

        .hex-input:focus {
            outline: none;
            border-color: rgb(var(--primary-color));
            box-shadow: 0 0 0 2px rgba(var(--primary-color), 0.2);
        }

        /* Dark mode styles for picker popup */
        .color-picker-popup .component-input label {
            color: #999;
        }

        .color-picker-popup .component-input input {
            background: #2a2a2a;
            color: #fff;
            border-color: rgba(128, 128, 128, 0.4);
        }

        .color-picker-popup .component-input input:focus {
            border-color: rgb(var(--primary-color));
        }

        .color-picker-popup .hex-prefix {
            background: rgba(128, 128, 128, 0.3);
            border-color: rgba(128, 128, 128, 0.4);
            color: #999;
        }

        .color-picker-popup .hex-input {
            background: #2a2a2a;
            color: #fff;
            border-color: rgba(128, 128, 128, 0.4);
        }

        .color-picker-popup .hex-input:focus {
            border-color: rgb(var(--primary-color));
        }

        /* iro.js slider styling */
        .IroSlider {
            margin-top: 6px !important;
            height: 20px !important;
        }

        .IroSliderGradient {
            height: 20px !important;
        }

        .IroSlider .IroHandle {
            top: -12px !important;
        }

        /* Color Preview Panel - minimal styles, uses actual site CSS */
        .color-preview {
            margin-bottom: 1.5rem;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid rgb(var(--background-mid));
            /* Ensure Tailwind opacity variables are set for color utilities */
            --tw-text-opacity: 1;
            --tw-bg-opacity: 1;
            --tw-border-opacity: 1;
        }

        /* Prevent links in preview from navigating */
        .color-preview a {
            pointer-events: none;
        }

        /* Override some navbar styles that conflict with page layout */
        .color-preview .navbar {
            position: relative;
        }

        /* Timeline dot border color utility */
        .border-secondary-color {
            border-color: rgb(var(--secondary-color));
        }

        /* AI Generate button in toolbar */
        .ai-generate-btn {
            background: linear-gradient(135deg, rgb(var(--primary-color)), rgb(var(--secondary-color)));
            color: rgb(var(--primary-color-contrast));
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            font-weight: 600;
            transition: filter 0.2s, transform 0.2s;
        }

        .ai-generate-btn:hover:not(:disabled) {
            filter: brightness(1.1);
            transform: translateY(-1px);
        }

        .ai-generate-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .ai-generate-btn .ai-icon {
            width: 1em;
            height: 1em;
            vertical-align: middle;
            margin-right: 0.3em;
        }

        /* AI Modal Overlay */
        .ai-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            backdrop-filter: blur(2px);
        }

        /* AI Modal */
        .ai-modal {
            background: rgb(var(--background-feature));
            border-radius: 12px;
            padding: 2rem;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            animation: modalSlideIn 0.2s ease-out;
        }

        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .ai-modal h3 {
            margin: 0 0 0.5rem 0;
            color: rgb(var(--heading-color));
            font-size: 1.5rem;
        }

        .ai-modal-description {
            color: rgb(var(--text-secondary));
            margin: 0 0 1.5rem 0;
            font-size: 0.9rem;
        }

        /* AI Modal Form Field */
        .ai-modal-field {
            margin-bottom: 1.5rem;
        }

        .ai-modal-field label {
            display: block;
            margin-bottom: 0.5rem;
            color: rgb(var(--text-main));
            font-weight: 600;
        }

        .ai-modal-field textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid rgb(var(--background-mid));
            border-radius: 6px;
            font-family: inherit;
            font-size: 1rem;
            resize: vertical;
            min-height: 80px;
            background: rgb(var(--background-body));
            color: rgb(var(--text-main));
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .ai-modal-field textarea:focus {
            outline: none;
            border-color: rgb(var(--primary-color));
            box-shadow: 0 0 0 3px rgba(var(--primary-color), 0.15);
        }

        .ai-modal-field textarea:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        /* AI Mode Options */
        .ai-mode-options {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .ai-mode-option {
            display: flex;
            flex-direction: column;
            padding: 0.75rem 1rem;
            border: 1px solid rgb(var(--background-mid));
            border-radius: 6px;
            cursor: pointer;
            transition: border-color 0.2s, background-color 0.2s;
            background: rgb(var(--background-body));
        }

        .ai-mode-option:hover {
            border-color: rgb(var(--primary-color));
        }

        .ai-mode-option.selected {
            border-color: rgb(var(--primary-color));
            background: rgba(var(--primary-color), 0.1);
        }

        .ai-mode-option input[type="radio"] {
            display: none;
        }

        .ai-mode-option span {
            display: block;
            font-weight: 600;
            color: rgb(var(--text-main));
        }

        .ai-mode-option small {
            display: block;
            color: rgb(var(--text-secondary));
            font-size: 0.8rem;
            margin-top: 0.25rem;
        }

        .ai-mode-option.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        /* AI Error */
        .ai-error {
            background: rgba(var(--secondary-color), 0.15);
            border: 1px solid rgba(var(--secondary-color), 0.3);
            color: rgb(var(--secondary-color));
            padding: 0.75rem;
            border-radius: 6px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        /* AI Modal Buttons */
        .ai-modal-buttons {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }

        .ai-cancel-btn {
            background: rgb(var(--background-mid));
            color: rgb(var(--text-main));
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            font-weight: 500;
            transition: filter 0.2s;
        }

        .ai-cancel-btn:hover:not(:disabled) {
            filter: brightness(1.1);
        }

        .ai-cancel-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .ai-generate-submit-btn {
            background: linear-gradient(135deg, rgb(var(--primary-color)), rgb(var(--secondary-color)));
            color: rgb(var(--primary-color-contrast));
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            font-weight: 600;
            transition: filter 0.2s, transform 0.2s;
        }

        .ai-generate-submit-btn:hover:not(:disabled) {
            filter: brightness(1.1);
            transform: translateY(-1px);
        }

        .ai-generate-submit-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        /* AI Image Upload */
        .ai-image-upload {
            border: 2px dashed rgb(var(--background-mid));
            border-radius: 8px;
            transition: border-color 0.2s, background-color 0.2s;
        }

        .ai-image-upload:hover {
            border-color: rgb(var(--primary-color));
        }

        .ai-image-upload-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            cursor: pointer;
            text-align: center;
            gap: 0.5rem;
        }

        .ai-image-upload-label.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        .ai-upload-icon {
            font-size: 2rem;
        }

        .ai-image-upload-label span {
            color: rgb(var(--text-main));
            font-weight: 500;
        }

        .ai-image-upload-label small {
            color: rgb(var(--text-secondary));
            font-size: 0.8rem;
        }

        /* AI Image Preview */
        .ai-image-preview {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            max-height: 200px;
        }

        .ai-image-preview img {
            width: 100%;
            height: auto;
            max-height: 200px;
            object-fit: cover;
            display: block;
        }

        .ai-image-remove {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.6);
            color: white;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background-color 0.2s;
        }

        .ai-image-remove:hover:not(:disabled) {
            background: rgba(0, 0, 0, 0.8);
        }

        .ai-image-remove:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
    </style>
</head>
