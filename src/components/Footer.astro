---
import {getSiteConfig} from "../lib/config/getSiteConfig";
import {getSiteCode} from "../lib/config/getSiteCode";
import {formatBuildCode} from "../lib/utils/buildUtils";
import { execSync } from 'child_process';

const siteConfig = await getSiteConfig();
const siteCode = getSiteCode();

// Get build metadata at build time
let gitCommit = '';
let submoduleCommit = '';
let buildTime = new Date().toISOString();

// Get main repo commit hash
try {
  gitCommit = execSync('git rev-parse --short HEAD', { encoding: 'utf-8' }).trim();
} catch (error) {
  console.warn('Could not get main repo git commit hash:', error);
}

// Get submodule commit hash for the active site
try {
  const submodulePath = `src/.sites/${siteCode}`;
  submoduleCommit = execSync(`git -C ${submodulePath} rev-parse --short HEAD`, { encoding: 'utf-8' }).trim();
} catch (error) {
  console.warn(`Could not get submodule git commit hash for ${siteCode}:`, error);
}

// Format commit info using shared utility
const buildCode = formatBuildCode(gitCommit, submoduleCommit);
const commitInfo = buildCode ? `${buildCode} • ` : '';

// Format build time as YYYY-MM-DD HH:MM:ss UTC
const buildDate = buildTime.replace('T', ' ').replace(/\.\d{3}Z$/, '') + ' UTC';
---

<footer>
  {siteConfig.footer.content.map((item, _) => (
      <div class="page-footer">
        {item.replace('[CURRENT_YEAR]', new Date().getFullYear().toString())}
      </div>
  ))}

  <div class="page-footer">
    Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
  </div>

  <div class="page-footer build-info">
      Build: {commitInfo}{buildDate}
  </div>
</footer>
