---
interface Props {
    filename: string;
}

import { getSiteConfig } from "../../lib/config/getSiteConfig";
import { getSiteCode } from "../../lib/config/getSiteCode";
import {getAllKeys} from "../../lib/utils/keyUtils";
import {KeyType} from "../../lib/utils/enums";
import { Comments } from "../bluesky/Comments";
import { getJson} from "../../lib/config/getJson";

const blueskyJson = await getJson(getSiteCode(), 'bluesky_posted.json');
// console.log('blueskyJson', blueskyJson);

const { filename } = Astro.props;
const siteConfig = await getSiteConfig();
const allCategories = await getAllKeys(KeyType.Categories);
// console.log(allCategories);
interface BlueskyPostEntry {
    post_id: string;
    post_uri: string;
    post_cid: string;
    post_url?: string;
}

// post_id values have varied across layouts (full-ish paths in the old
// single-site layout, basenames or _drafts/-prefixed names now), so match
// on the basename, which is stable: filenames are date-prefixed and unique.
const basename = (p: string) => p.replace(/\/+$/, '').split('/').pop() ?? p;

function getBlueskyPostData(originalFilename: string): { post_uri: string; post_url?: string } | null {
    if (!siteConfig.bluesky.include) {
        return null;
    }
    const thisId = basename(originalFilename);
    // Find the matching entry
    const entry = blueskyJson.find((entry: BlueskyPostEntry) => basename(entry.post_id) === thisId);
    if (entry) {
        return {
            post_uri: entry.post_uri,
            post_url: entry.post_url
        };
    }
    return null;
}
const blueskyPostData = getBlueskyPostData(filename);
---
{siteConfig.bluesky.include && blueskyPostData &&
<hr />
<div>
    <!--{ blueskyPostData }-->
    <Comments
            client:load
            client:only="solid-js"
            atprotoURI={blueskyPostData.post_uri}
            postUrl={blueskyPostData.post_url}
            categories={allCategories}
    />
</div>}
