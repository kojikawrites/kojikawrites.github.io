---
import getSafeId from "../../lib/utils/toSafeId";
interface Props {
	id?: string,
}

const {id} = Astro.props
const contentWarningId = `cw-${getSafeId(id)}`;
const warningId = `${contentWarningId}-warning`;
const hiddenId = `${contentWarningId}-hidden`;
import WarningTriangleSvg from "../../assets/images/content-warning/warning-triangle.svg"
---
<style>

    @media print {
        .hidden-content {
            @apply block;
        }

        .hidden-content-warning {
            @apply hidden;
        }
    }
</style>

<div id={contentWarningId} transition:persist>
    <button id={warningId} class="hidden-content-warning p-4 border rounded-lg w-full
                                  cursor-pointer
                                  font-bold text-lg text-center lg:ml-2 mt-1 mb-4"
            aria-expanded="false" aria-controls={hiddenId}>
        <span class="flex flex-row align-middle justify-center items-center space-x-2">

            <WarningTriangleSvg class="icon-warning pl-2 h-20 lg:px-0 lg:h-5" />
            <slot name="warning" />
            <WarningTriangleSvg class="icon-warning pr-2 h-20 lg:px-0 lg:h-5" />
        </span>
    </button>

    <div id={hiddenId} class="hidden-content hidden min-w-fit">
        <slot name="content" />
    </div>

</div>
<script is:inline data-astro-rerun define:vars={{ warningId, hiddenId }}>
    (function() { // IIFE
        function refreshDivs() {
            const toggleDiv = document.getElementById(warningId);
            const contentDiv = document.getElementById(hiddenId);

            if (!toggleDiv || !contentDiv) {
                console.warn("Can't find toggleDiv or contentDiv");
                return;
            }

            // match fill to warning color
            const warningStyle = window?.getComputedStyle(toggleDiv);
            if (warningStyle?.color) {
                toggleDiv.style.fill = warningStyle.color;
            }

            // Click handler function
            function handleToggleClick() {
                const isExpanded = toggleDiv.getAttribute('aria-expanded') === 'true';
                if (!isExpanded) {
                    contentDiv.classList.remove('hidden');
                    toggleDiv.classList.add('hidden');
                    toggleDiv.setAttribute('aria-expanded', 'true');
                } else {
                    // contentDiv.classList.add('hidden');
                    toggleDiv.setAttribute('aria-expanded', 'false');
                }
            }

            // Initialize global listener storage if needed
            if (!window.__contentWarningListeners) {
                window.__contentWarningListeners = {};
            }

            // Remove old listener if it exists (prevents memory leaks on page transitions)
            if (window.__contentWarningListeners[warningId]) {
                toggleDiv.removeEventListener('click', window.__contentWarningListeners[warningId]);
            }

            // Store listener reference for cleanup on next run
            window.__contentWarningListeners[warningId] = handleToggleClick;

            // Add listener
            toggleDiv.addEventListener('click', handleToggleClick);
        }

        refreshDivs();
    })();
</script>
