---
import { ClientRouter } from 'astro:transitions'

import {getSiteCode} from '../lib/config/getSiteCode'
import StyleHelper from "./StyleHelper.astro";

export interface Props {
    title: string
    description: string
    permalink: string
}

const { title, description, permalink } = Astro.props
const siteCode = getSiteCode();
const isDev = import.meta.env.DEV;

---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />

<link rel="alternate" type="application/rss+xml"
      title={title}
      href={new URL("rss.xml", Astro.site)}
/>
<link rel="sitemap" href=`/sitemap-index.xml` />
<link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png">
<link rel="manifest" href="/favicons/site.webmanifest">

<!-- viewport setting -->
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<!-- lightbox -->
<script is:inline src="/scripts/prebuilt/spotlight.bundle.js" data-astro-rerun />

<!-- Twitter -->
<!--<meta property="twitter:card" content="summary_large_image" />-->
<!--<meta property="twitter:url" content={permalink} />-->
<!--<meta property="twitter:title" content={title} />-->
<!--<meta property="twitter:description" content={description} />-->
<!--<meta property="twitter:image" content={socialUrl} />-->

<ClientRouter />
<StyleHelper/>

<!-- This is intentionally inlined to avoid FOUC -->
<script is:inline data-astro-rerun>
    // localStorage.clear();
    (function() { // IIFE
        const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

        // Global helper to get effective theme (resolves 'system' to actual 'light' or 'dark')
        // This can be called from other inline scripts that can't import modules
        window.getEffectiveTheme = function() {
            const storedTheme = localStorage.getItem('theme');
            const prefersDark = darkModeMediaQuery.matches;
            if (!storedTheme || storedTheme === 'system') {
                return prefersDark ? 'dark' : 'light';
            }
            return storedTheme === 'dark' ? 'dark' : 'light';
        };

        function setTheme() {
            const root = document.documentElement;
            const effectiveTheme = window.getEffectiveTheme();

            // set the theme.
            if (effectiveTheme === 'dark') {
                console.log('Setting dark mode');
                root.classList.add('theme-dark');
            } else {
                console.log('Setting light mode');
                root.classList.remove('theme-dark');
            }
        }

        // Wrapper for media query handler - only apply if theme is 'system' or not set
        function handleMediaQueryChange(e) {
            const storedTheme = localStorage.getItem('theme');
            // Only respond to system changes if theme is 'system' or not explicitly set
            if (!storedTheme || storedTheme === 'system') {
                const root = document.documentElement;
                if (e.matches) {
                    console.log('System switched to dark mode');
                    root.classList.add('theme-dark');
                } else {
                    console.log('System switched to light mode');
                    root.classList.remove('theme-dark');
                }
            }
        }

        // Remove old listeners if they exist (prevents memory leaks on page transitions)
        if (window.__baseHeadThemeListeners) {
            window.removeEventListener('storage', window.__baseHeadThemeListeners.setTheme);
            darkModeMediaQuery.removeEventListener('change', window.__baseHeadThemeListeners.handleMediaQueryChange);
        }

        // Store listener references globally for cleanup on next run
        window.__baseHeadThemeListeners = {
            setTheme: setTheme,
            handleMediaQueryChange: handleMediaQueryChange
        };

        // Initial theme set
        setTheme();

        // Add listeners
        window.addEventListener('storage', setTheme);
        darkModeMediaQuery.addEventListener('change', handleMediaQueryChange);
    })();

</script>

{isDev && (
<!-- Menu update handler - reloads page when menu changes (dev mode only) -->
<!-- Keystatic pages ignore this event to preserve draft state -->
<script>
    if (import.meta.hot) {
        import.meta.hot.on('menu-updated', () => {
            console.log('[HMR] Menu updated, reloading page...');
            window.location.reload();
        });
    }
</script>
)}

