---
interface Props {
    id?: string;
    caption?: string;
    smCols?: number | string;
    lgCols?: number | string;
}


import toSafeId from '../../lib/utils/toSafeId';

const { id:rawId, caption = "Image Gallery", smCols, lgCols } = Astro.props;

// Generate a unique ID if none provided
const id = rawId ?? toSafeId("gallery");
const captionId = `caption_${id}`;

// Build grid classes - use defaults if not specified (empty string from select counts as falsy)
const smGridClass = smCols ? `grid-cols-${smCols}` : 'grid-cols-[repeat(auto-fit,_minmax(25%,_1fr))]';
const lgGridClass = lgCols ? `lg:grid-cols-${lgCols}` : 'lg:grid-cols-[repeat(auto-fit,_minmax(172px,_1fr))]';
---
<div class="lg:left-4">
    <div id={id} class:list={[
        "lightbox-gallery grid w-fit flex-1 place-items-stretch space-x-1 lg:space-x-0",
        smGridClass,
        lgGridClass
    ]}>
        <slot />
    </div>
    <div id={captionId} class="lightbox-gallery-caption">
        {caption}
    </div>
</div>
<script is:inline define:vars={{id, captionId}} data-astro-rerun>
    // IIFE to avoid polluting global scope when multiple galleries exist on the same page
    (function() {
        const galleryId = id;
        const galleryCaptionId = captionId;

        function initGallery() {
            const galleryDiv = document.getElementById(galleryId);
            if (!galleryDiv) {
                return [];
            }

            const galleryEntries = galleryDiv.querySelectorAll('[data-gallery-entry]');
            const spotlightTheme = (window.getEffectiveTheme() === 'dark') ? 'dark' : 'white';
            let idx = 0;
            return Array.from(galleryEntries).map(div => {
                const img = div.querySelector('img');
                img.id = `${galleryId}_${idx}`;
                idx += 1;
                return {
                    src: img.src || '',
                    title: div.getAttribute('data-alt') || '',
                    description: div.getAttribute('data-description') || '',
                    theme: spotlightTheme
                };
            });
        }

        const galleryList = initGallery();

        // Add click handlers after galleryList is built
        const galleryDiv = document.getElementById(galleryId);
        if (galleryDiv) {
            const images = galleryDiv.querySelectorAll('[data-gallery-entry] img');
            images.forEach((img, idx) => {
                img.addEventListener("click", _ => {
                    Spotlight.show(galleryList, null, idx);
                });
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const gallery = document.getElementById(galleryId);
            const caption = document.getElementById(galleryCaptionId);
            const images = gallery.querySelectorAll('img');

            const updateCaptionSpan = () => {
                caption.style.maxWidth = `${gallery.clientWidth}px`
            };

            const checkAllImagesLoaded = () => {
                const allLoaded = Array.from(images).every(img => img.complete && img.naturalWidth !== 0);
                if (allLoaded) {
                    updateCaptionSpan();
                }
            };

            images.forEach(img => {
                if (img.complete) {
                    checkAllImagesLoaded();
                } else {
                    img.addEventListener('load', checkAllImagesLoaded);
                    img.addEventListener('error', checkAllImagesLoaded);
                }
            });

            updateCaptionSpan();
            window.addEventListener('resize', updateCaptionSpan);
        });
    })();
</script>
