# Root Environment Configuration
# Copy this file to .env and set your site code
#
# This file should ONLY contain SITE_CODE which points to your site directory.
# All other site-specific configuration should be in:
#   src/.sites/[SITE_CODE]/.env
#
# See src/.sites/[SITE_CODE]/.env.example for site-specific variables.

# Site code - must match a directory name in src/.sites/
# Example: example.com
SITE_CODE=example.com
